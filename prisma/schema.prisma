// Это ваш основной файл схемы Prisma.
// Здесь мы описываем структуру нашей будущей базы данных (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  url = env("DATABASE_URL")
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Пользователи и безопасность
// -----------------------------------------------------------------------------
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  passwordHash String?
  role         Role     @default(USER)
  avatar       String?
  name         String?  // Отображаемое имя
  phone        String?  // Номер телефона
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders      Order[]
  reviews     Review[]
  wishlist    Wishlist[]
}

enum Role {
  USER
  ADMIN
}

// -----------------------------------------------------------------------------
// Продукты (Товары, которые можно купить)
// -----------------------------------------------------------------------------
model Course {
  id              String   @id @default(cuid())
  category        String   @default("beginners") // beginners, intermediate, advanced
  title           String
  description     String
  fullDescription String?  @db.Text
  features        String[] // Массив фичей
  price           Float
  imageUrl        String?
  author          String?
  authorPhoto     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
}

model Consultation {
  id              String   @id @default(cuid())
  category        String   @default("private")
  title           String
  description     String
  fullDescription String?  @db.Text
  features        String[]
  price           Float
  imageUrl        String?
  author          String?
  authorPhoto     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
}

model Tour {
  id              String   @id @default(cuid())
  title           String
  description     String
  fullDescription String?  @db.Text
  features        String[]
  price           Float
  imageUrl        String?
  date            String?
  location        String?
  author          String?
  authorPhoto     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Контентая часть (Блог, Медиа, FAQ, Отзывы)
// -----------------------------------------------------------------------------
model Article {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  content     String   @db.Text
  imageUrl    String?
  author      String?
  authorPhoto String?
  tag         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Video {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  videoUrl     String
  thumbnailUrl String?
  tag          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Podcast {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  audioUrl    String
  duration    String?
  tag         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Recipe {
  id              String   @id @default(cuid())
  title           String
  description     String?  @db.Text
  fullDescription String?  @db.Text
  imageUrl        String?
  time            String?
  tag             String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  course    String
  text      String   @db.Text
  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// Система покупок и заказов (Замена моковых покупок в LocalStorage)
// -----------------------------------------------------------------------------
model Order {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  guestName   String?
  productName String?     // Название товара (курс, тур, консультация)
  itemId      String
  itemType    ItemType
  amount      Float
  status      OrderStatus @default(PENDING)
  notified    Boolean     @default(false)
  notes       String?                        // preferred date/time, guest contact info
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// Комментарии к статьям блога
// -----------------------------------------------------------------------------
model Comment {
  id        String   @id @default(cuid())
  articleId String
  name      String
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@index([articleId])
}

enum ItemType {
  COURSE
  TOUR
  CONSULTATION
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// -----------------------------------------------------------------------------
// Служба поддержки
// -----------------------------------------------------------------------------
model SupportTicket {
  id          String       @id @default(cuid())
  name        String
  email       String
  subject     String
  message     String       @db.Text
  reply       String?      @db.Text
  readByUser  Boolean      @default(false)
  status      TicketStatus @default(NEW)
  createdAt   DateTime     @default(now())

  @@index([email])
  @@index([status])
}

// -----------------------------------------------------------------------------
// Подписчики рассылки
// -----------------------------------------------------------------------------
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

// -----------------------------------------------------------------------------
// Рейтинги и отзывы
// -----------------------------------------------------------------------------
model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  itemType  ItemType
  rating    Int      // 1-5
  text      String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([userId, itemId, itemType])
  @@index([itemId, itemType])
}

// -----------------------------------------------------------------------------
// Список желаний (Избранное)
// -----------------------------------------------------------------------------
model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  itemType  ItemType
  createdAt DateTime @default(now())

  @@unique([userId, itemId, itemType])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// Промокоды
// -----------------------------------------------------------------------------
enum DiscountType {
  PERCENT
  FIXED
}

model PromoCode {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  maxUses       Int?
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
}

// -----------------------------------------------------------------------------
// Команда (На странице "О нас")
// -----------------------------------------------------------------------------
model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  imageUrl  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Сброс пароля
// -----------------------------------------------------------------------------
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// -----------------------------------------------------------------------------
// Настройки сайта (singleton — один record с id = "singleton")
// -----------------------------------------------------------------------------
model SiteSettings {
  id            String   @id @default("singleton")
  addressLine   String   @default("")
  email         String   @default("")
  phone         String   @default("")
  instagram     String   @default("")
  telegram      String   @default("")
  youtube       String   @default("")
  yearsExp      String   @default("5+")
  studentsCount String   @default("10k+")
  updatedAt     DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Слайды для героических секций страниц (управляются в админ-панели)
// -----------------------------------------------------------------------------
enum SlideMediaType {
  IMAGE
  VIDEO
}

model PageSlide {
  id        String         @id @default(cuid())
  pageKey   String         // "blog", "courses", "courses-beginners", "tours", etc.
  url       String         // URL изображения или видео
  mediaType SlideMediaType @default(IMAGE)
  title     String?
  sortOrder Int            @default(0)
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())

  @@index([pageKey, active])
}
