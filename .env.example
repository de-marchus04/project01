# Database (PostgreSQL / Neon)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth
AUTH_SECRET="your-secret-here"          # Generate: openssl rand -base64 32
AUTH_URL="https://yourdomain.com"
AUTH_TRUST_HOST=true

# OAuth — Google (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub (github.com/settings/developers)
GITHUB_ID=
GITHUB_SECRET=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM="YOGA.LIFE <noreply@yourdomain.com>"

# Admin seed password (used by: prisma/seed.ts)
# IMPORTANT: Change this before running seed in production!
ADMIN_DEFAULT_PASSWORD=change_me_before_seeding

# Rate Limiting (optional — Upstash Redis for serverless-safe rate limiting)
# Without these, rate limiting uses in-memory storage which resets on cold starts.
# Get credentials at: https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Site URL (used in emails, robots.txt sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# CORS allowed origins (comma-separated, for API protection)
ALLOWED_ORIGINS=https://yourdomain.com

# Open Graph locale (default: uk_UA)
NEXT_PUBLIC_OG_LOCALE=uk_UA

# Admin notification email (receives alert on new support ticket)
ADMIN_NOTIFY_EMAIL=

# Google Analytics 4 (optional, leave empty to disable)
NEXT_PUBLIC_GA_ID=
