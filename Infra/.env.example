# --- API security secrets ---
Security__JwtKey=replace-with-strong-random-48b
Security__AdminCreationKey=replace-with-strong-random-36b
Security__JwtKeyVersion=20260223

# --- Database ---
POSTGRES_PASSWORD=replace-with-strong-password
ConnectionStrings__DefaultConnection=Host=postgres;Database=YogaPlatformDb;Username=postgres;Password=${POSTGRES_PASSWORD}

# --- CORS ---
Cors__AllowedOrigins__0=https://your-production-domain.com

# --- Monitoring / Alerting ---
ALERT_WEBHOOK_URL=https://your-alert-webhook.example.com/alerts
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
