# --- Postgres ---
POSTGRES_DB=YogaPlatformDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password

# --- API security secrets ---
Security__JwtKey=replace-with-strong-random-48b
Security__AdminCreationKey=replace-with-strong-random-36b
Security__JwtKeyVersion=20260224

# --- Monitoring / Alerting ---
ALERT_WEBHOOK_URL=https://your-alert-webhook.example.com/alerts
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password
