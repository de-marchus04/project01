{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=YogaPlatformDb;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Database": {
    "ApplySeedOnStartup": true
  },
  "Security": {
    "JwtKey": "YogaPlatform-Super-Secret-JWT-Key-2026-Change-This-Now",
    "AdminCreationKey": "YogaAdmin2026!ChangeThis",
    "AdminUsernames": [
      "admin",
      "dmitrij_admin"
    ]
  }
}
