{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=YogaPlatformDb;Username=postgres;Password=${POSTGRES_PASSWORD}",
    "Redis": "localhost:6379"
  },
  "Database": {
    "ApplySeedOnStartup": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5500",
      "http://127.0.0.1:3000",
      "http://127.0.0.1:5500"
    ]
  },
  "Security": {
    "JwtKey": "${JWT_KEY}",
    "AdminCreationKey": "${ADMIN_CREATION_KEY}",
    "AdminUsernames": [
      "admin",
      "dmitrij_admin"
    ]
  }
}
