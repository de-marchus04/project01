{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "Database": {
    "ApplySeedOnStartup": false
  },
  "Security": {
    "JwtKey": "REPLACE_WITH_YOUR_VERY_LONG_SECRET_KEY_MIN_32_CHARS",
    "AdminCreationKey": "REPLACE_WITH_YOUR_SECRET_ADMIN_CREATION_KEY",
    "JwtKeyVersion": "v1",
    "AdminUsernames": [
      "admin",
      "dmitrij_admin"
    ]
  }
}
